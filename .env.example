# ============================================================
# Banco Central de Chile — BDE API
# Registro en: https://si3.bcentral.cl/estadisticas/Principal1/Web_Services/index.htm
# ============================================================
BCENTRAL_USER=tu_email@ejemplo.com
BCENTRAL_PASS=tu_contraseña

# ============================================================
# CMF Chile — API v3
# Registro en: https://api.cmfchile.cl
# ============================================================
CMF_API_KEY=tu_api_key_cmf

# API key pública de la SBIFv3 para estados bancarios (registro gratuito en api.sbif.cl).
# Opcional: si se omite, se usa la clave pública por defecto.
CMF_SBIF_APIKEY=

# ============================================================
# Base de datos
# ============================================================
DB_PATH=data/finanzas_chile.duckdb

# ============================================================
# Scheduler
# ============================================================
# Hora de ejecución diaria (formato HH:MM, timezone America/Santiago)
DAILY_FETCH_TIME=08:00
TIMEZONE=America/Santiago
# Si es true, `python main.py serve` arranca el scheduler embebido en el mismo proceso
# que la API web (proceso único; la BD se abre en lectura/escritura).
RUN_SCHEDULER_IN_APP=false

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
